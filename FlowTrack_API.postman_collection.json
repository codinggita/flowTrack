{
  "info": {
    "name": "FlowTrack API",
    "description": "Complete API documentation for FlowTrack — Personal Finance Management Platform.\n\n**Base URL:** `https://flowtrack-d4d1.onrender.com`\n\n**Auth:** All protected routes require `Authorization: Bearer {{token}}` header.\n\nSteps:\n1. Run `POST /api/auth/register` or `POST /api/auth/login`\n2. Copy the `token` from the response\n3. Set it as the `token` variable in your environment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://flowtrack-d4d1.onrender.com", "type": "string" },
    { "key": "token",    "value": "",                                      "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Swaraj Prajapati\",\n  \"email\": \"swaraj@example.com\",\n  \"password\": \"Password123\",\n  \"phone\": \"+91 98765 43210\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["const res = pm.response.json();", "if (res.data && res.data.token) {", "  pm.collectionVariables.set('token', res.data.token);", "  console.log('Token saved:', res.data.token);", "}"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"swaraj@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },
        {
          "name": "Google Auth",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/google", "host": ["{{base_url}}"], "path": ["api","auth","google"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": \"<google_id_token_here>\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/forgot-password", "host": ["{{base_url}}"], "path": ["api","auth","forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"swaraj@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/reset-password/:token", "host": ["{{base_url}}"], "path": ["api","auth","reset-password",":token"], "variable": [{ "key": "token", "value": "<reset_token_from_email>" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"NewPassword123\"\n}"
            }
          }
        },
        {
          "name": "Get Me (Profile)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api","auth","me"] }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/health", "host": ["{{base_url}}"], "path": ["api","health"] }
          }
        }
      ]
    },
